<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.flashsale.mapper.OrderMapper">

    <resultMap id="orderMap" type="com.flashsale.entity.Order">
        <id column="id" property="id"/>
        <result column="order_no" property="orderNo"/>
        <result column="user_id" property="userId"/>
        <result column="product_id" property="productId"/>
        <result column="event_id" property="eventId"/>
        <result column="product_name" property="productName"/>
        <result column="product_image" property="productImage"/>
        <result column="quantity" property="quantity"/>
        <result column="unit_price" property="unitPrice"/>
        <result column="total_price" property="totalPrice"/>
        <result column="order_type" property="orderType"/>
        <result column="status" property="status"/>
        <result column="pay_channel" property="payChannel"/>
        <result column="pay_time" property="payTime"/>
        <result column="expire_time" property="expireTime"/>
        <result column="address_id" property="addressId"/>
        <result column="remark" property="remark"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO orders (order_no, user_id, product_id, event_id, product_name,
                            product_image, quantity, unit_price, total_price,
                            order_type, status, expire_time, address_id, remark)
        VALUES (#{orderNo}, #{userId}, #{productId}, #{eventId}, #{productName},
                #{productImage}, #{quantity}, #{unitPrice}, #{totalPrice},
                #{orderType}, #{status}, #{expireTime}, #{addressId}, #{remark})
    </insert>

    <select id="selectById" resultMap="orderMap">
        SELECT * FROM orders WHERE id = #{id}
    </select>

    <select id="selectByOrderNo" resultMap="orderMap">
        SELECT * FROM orders WHERE order_no = #{orderNo}
    </select>

    <select id="selectByUserId" resultMap="orderMap">
        SELECT * FROM orders WHERE user_id = #{userId} ORDER BY created_at DESC
    </select>

    <select id="selectByUserIdAndStatus" resultMap="orderMap">
        SELECT * FROM orders WHERE user_id = #{userId} AND status = #{status}
        ORDER BY created_at DESC
    </select>

    <update id="updateStatus">
        UPDATE orders SET status = #{status} WHERE id = #{id}
    </update>

    <update id="payOrder">
        UPDATE orders
        SET status = 1, pay_channel = #{payChannel}, pay_time = #{payTime}
        WHERE id = #{id} AND status = 0
    </update>

    <select id="selectExpiredOrders" resultMap="orderMap">
        SELECT * FROM orders
        WHERE status = 0 AND expire_time &lt; #{now}
    </select>

</mapper>
